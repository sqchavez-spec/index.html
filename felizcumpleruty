  <script>
    // --- Lógica del Sobre Mejorada ---
    document.addEventListener('DOMContentLoaded', function() {
      const sobre = document.getElementById('sobre-animado');
      
      if (sobre) {
        sobre.addEventListener('click', function() {
          if (sobre.classList.contains('is-open')) return;
          
          sobre.classList.add('is-open');
          
          setTimeout(() => {
            const screen = document.getElementById('envelope-screen');
            screen.classList.add('hide-envelope');
            
            setTimeout(() => {
              const formView = document.getElementById('form-view');
              formView.style.display = 'block';
              
              setTimeout(() => {
                formView.style.opacity = '1';
                setTimeout(() => { screen.style.display = 'none'; }, 800);
              }, 50);
              
            }, 500);
            
          }, 1400);
        });
      }
    });
  </script>
